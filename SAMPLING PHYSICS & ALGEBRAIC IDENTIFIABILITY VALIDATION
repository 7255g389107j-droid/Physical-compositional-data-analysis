# --- 1. DATA PREPARATION ---
P_raw <- as.matrix(Dataset[, colSums(Dataset != 0) > 0])
sample_ids <- rownames(P_raw)
if(is.null(sample_ids)) sample_ids <- paste0("S_", 1:nrow(P_raw))
n_s <- nrow(P_raw)
n_t <- ncol(P_raw)

# --- 2. VECTORIZED FLAT-INDEX NOISE FLOOR EXTRACTOR ---
non_zero_mask <- P_raw > 0
huge_value <- max(P_raw) + 1.0
P_temp <- P_raw
P_temp[!non_zero_mask] <- huge_value

min_col_idx <- max.col(-P_temp, ties.method = "first")
full_minima <- P_raw[1:n_s + (min_col_idx - 1) * n_s]
full_minima[rowSums(non_zero_mask) == 0] <- NA 
names(full_minima) <- sample_ids

# --- 3. COMPOSITION SPACE MAPPING (Proportions / π-Space) ---
row_totals <- rowSums(P_raw)
row_totals[row_totals == 0] <- 1  
Pi_mat <- P_raw / row_totals

# UNIFIED DIGITAL RESOLUTION INVERSION
is_raw_counts <- any(row_totals > 1.01)
if(is_raw_counts) {
  eff_lib_size <- row_totals
} else {
  eff_lib_size <- 1 / full_minima
}

# --- 4. TRUE ALL-PAIRWISE PHYSICS ENGINE (Dynamic Worst-Case Extraction) ---
alpha_input <- 0.01 
z_alpha_in  <- abs(qnorm(alpha_input / 2))

# CRITICAL ADVANCEMENT: Scan ALL adjacent sorted pairs per row using high-speed margin apply
# This instantly calculates the required_wt for EVERY adjacent pair in the entire composition space.
# We then mathematically extract the TRUE absolute maximum required_wt per row.

calc_true_worst_bounds <- function(pi_row) {
  # Keep only non-zero components and sort them in ascending order
  nz_pi <- sort(pi_row[pi_row > 0])
  len <- length(nz_pi)
  
  if (len < 2) return(c(NA, NA, NA, NA)) # Insufficient components
  
  # Calculate adjacent differences and sums for ALL pairs simultaneously
  pi_j_vec <- nz_pi[1:(len - 1)]
  pi_i_vec <- nz_pi[2:len]
  
  deltas <- pi_i_vec - pi_j_vec
  sums   <- pi_i_vec + pi_j_vec
  
  # Handle absolute ties mathematically
  deltas[deltas == 0] <- 1e-9
  
  # Compute Required wt across ALL components in this row
  all_required_wts <- (z_alpha_in^2) * sums / (deltas^2)
  
  # Identify the index of the absolute worst case (where required_wt is maximized)
  worst_idx <- which.max(all_required_wts)
  
  # Extract the true worst parameters
  true_worst_wt    <- all_required_wts[worst_idx]
  true_worst_delta <- deltas[worst_idx]
  
  # Best case parameters (Maximum span: Max component vs Non-zero Min component)
  best_delta    <- nz_pi[len] - nz_pi[1]
  best_sum      <- nz_pi[len] + nz_pi[1]
  if(best_delta == 0) best_delta <- 1e-9
  true_best_wt  <- (z_alpha_in^2) * best_sum / (best_delta^2)
  
  return(c(true_worst_wt, true_worst_delta, true_best_wt, best_delta))
}

# Execute the high-speed row-wise parallel scan matrix mapping
bounds_matrix <- t(apply(Pi_mat, 1, calc_true_worst_bounds))

required_wt_strict    <- bounds_matrix[, 1]
min_major_delta       <- bounds_matrix[, 2]
required_wt_lenient    <- bounds_matrix[, 3]
max_major_delta       <- bounds_matrix[, 4]

# --- 5. VECTORIZED MATHEMATICAL INVERSION ---
required_scale_strict  <- 1 / min_major_delta
required_scale_lenient <- 1 / max_major_delta

z_sq_back_strict      <- eff_lib_size * (min_major_delta^2) / (required_wt_strict * (min_major_delta^2) / (z_alpha_in^2)) # Mathematical simplification
# Direct reverse-engineering of alpha based on actual eff_lib_size vs true worst-case parameters
# Formula: Z_back = sqrt(eff_lib_size * delta^2 / sum) -> since required_wt = Z^2 * sum / delta^2 -> sum/delta^2 = required_wt / Z^2
z_sq_back_strict      <- eff_lib_size * (z_alpha_in^2) / required_wt_strict
z_back_strict         <- sqrt(pmax(0, z_sq_back_strict))
alpha_back_strict     <- pnorm(-z_back_strict) * 2
safe_level_pct_strict <- (1 - alpha_back_strict) * 100

# --- 6. RIGID PHYSICS-BASED FILTERING ENGINE (DIMENSION-SAFE & FULLY VECTORIZED) ---
rel_status_mat <- matrix(-1, nrow = n_s, ncol = n_t, dimnames = list(sample_ids, colnames(P_raw)))
rel_status_mat[non_zero_mask] <- 0

# Identification of safe rows using the TRUE absolute worst-case required_wt boundary
sample_is_safe <- (!is.na(required_wt_strict) & (eff_lib_size >= required_wt_strict))

if (any(sample_is_safe)) {
  safe_mask <- non_zero_mask[sample_is_safe, , drop = FALSE]
  replacement_values <- matrix(0, nrow = sum(sample_is_safe), ncol = n_t)
  replacement_values[safe_mask] <- 1
  rel_status_mat[sample_is_safe, ] <- replacement_values
}

urt_mask <- colSums(rel_status_mat == 1) == n_s
urt_list <- colnames(P_raw)[urt_mask]

# --- 7. REPORT CONSTRUCTION & LOGGING ---
Analysis_Report <- data.frame(
  Sample_ID                = sample_ids,
  Effective_Library_Size   = eff_lib_size,
  Required_Scale_Strict    = required_scale_strict,
  Required_wt_Strict_Worst = required_wt_strict,
  Required_Scale_Lenient   = required_scale_lenient,
  Required_wt_Lenient_Best = required_wt_lenient,
  Safe_Evaluation_Percent  = safe_level_pct_strict,
  row.names                = 1
)

# Output Execution Results
print("========================================================================")
print("             TRUE ALL-PAIRWISE PHYSICS BOUNDS REPORT                     ")
print("========================================================================")
print(head(Analysis_Report, n = 100))

print("========================================================================")
print("             UNIVERSAL RELIABLE TARGETS (URT LIST VIA Z_ALPHA)          ")
print("========================================================================")
if(length(urt_list) > 0) {
  print(urt_list)
} else {
  print("No components survived the global Z_alpha threshold across all samples.")
}
print("========================================================================")
