# --- 1. DATA PREPARATION ---
P_raw <- as.matrix(Dataset[, colSums(Dataset != 0) > 0])
sample_ids <- rownames(P_raw)
if(is.null(sample_ids)) sample_ids <- paste0("S_", 1:nrow(P_raw))
n_s <- nrow(P_raw)
n_t <- ncol(P_raw)

# --- 2. VECTORIZED FLAT-INDEX NOISE FLOOR EXTRACTOR ---
non_zero_mask <- P_raw > 0
huge_value <- max(P_raw) + 1.0
P_temp <- P_raw
P_temp[!non_zero_mask] <- huge_value

min_col_idx <- max.col(-P_temp, ties.method = "first")
full_minima <- P_raw[1:n_s + (min_col_idx - 1) * n_s]
full_minima[rowSums(non_zero_mask) == 0] <- NA 
names(full_minima) <- sample_ids

# --- 3. COMPOSITION SPACE MAPPING (Proportions / π-Space) ---
row_totals <- rowSums(P_raw)
row_totals[row_totals == 0] <- 1  
Pi_mat <- P_raw / row_totals

# UNIFIED DIGITAL RESOLUTION INVERSION
is_raw_counts <- any(row_totals > 1.01)
if(is_raw_counts) {
  eff_lib_size <- row_totals
} else {
  eff_lib_size <- 1 / full_minima
}

# --- 4. TRUE POST-CUTOFF ALL-PAIRWISE PHYSICS & NON-INVERSION ENGINE ---
alpha_input <- 0.01 
z_alpha_in  <- abs(qnorm(alpha_input / 2))

calc_post_cutoff_physics_metrics <- function(pi_row, current_n) {
  nz_pi <- pi_row[pi_row > 0]
  if (length(nz_pi) < 2) return(c(NA, NA, NA, NA, 0, 0, length(nz_pi)))
  
  # Apply the 10x safety cutoff baseline FIRST (LOD Gate)
  pi_min_observed <- min(nz_pi)
  cutoff_threshold <- pi_min_observed * 10
  major_pi <- sort(nz_pi[nz_pi >= cutoff_threshold])
  
  len_major <- length(major_pi)
  if (len_major < 2) return(c(NA, NA, NA, NA, 0, 0, len_major))
  
  # Calculate adjacent differences and sums for surviving major components
  pi_j_vec <- major_pi[1:(len_major - 1)]
  pi_i_vec <- major_pi[2:len_major]
  
  deltas <- pi_i_vec - pi_j_vec
  sums   <- pi_i_vec + pi_j_vec
  deltas[deltas == 0] <- 1e-9
  
  # Compute Required wt across ALL major adjacent components in this row
  all_required_wts <- (z_alpha_in^2) * sums / (deltas^2)
  
  # Count valid non-inversion adjacent pairs based on actual sampling physics window
  valid_pairs_count <- sum(current_n >= all_required_wts)
  total_major_pairs <- length(all_required_wts)
  
  # Identify the true worst case among the major components (Strict Bound)
  worst_idx        <- which.max(all_required_wts)
  true_worst_wt    <- all_required_wts[worst_idx]
  true_worst_delta <- deltas[worst_idx]
  
  # Best case parameters (Maximum span: Max major component vs Min major component)
  best_delta   <- major_pi[len_major] - major_pi[1]
  best_sum     <- major_pi[len_major] + major_pi[1]
  if(best_delta == 0) best_delta <- 1e-9
  true_best_wt <- (z_alpha_in^2) * best_sum / (best_delta^2)
  
  return(c(true_worst_wt, true_worst_delta, true_best_wt, best_delta, valid_pairs_count, total_major_pairs, len_major))
}

# MAXIMUM SPEED EXECUTION VIA FIXED-LENGTH VECTOR QUANTIZATION (vapply)
bounds_matrix <- t(vapply(1:n_s, function(i) {
  calc_post_cutoff_physics_metrics(Pi_mat[i, ], eff_lib_size[i])
}, FUN.VALUE = numeric(7)))

required_wt_strict    <- bounds_matrix[, 1]
min_major_delta       <- bounds_matrix[, 2]
required_wt_lenient    <- bounds_matrix[, 3]
max_major_delta       <- bounds_matrix[, 4]
valid_non_inv_pairs   <- bounds_matrix[, 5]
total_major_pairs     <- bounds_matrix[, 6]
surviving_components  <- bounds_matrix[, 7]

# --- 5. VECTORIZED MATHEMATICAL INVERSION & CALCULATIONS ---
required_scale_strict  <- 1 / min_major_delta
required_scale_lenient <- 1 / max_major_delta

# Direct empirical Z-score extraction based on the actual physical sampling depth vs the target boundary
z_sq_back_strict      <- eff_lib_size * (z_alpha_in^2) / required_wt_strict
z_back_strict         <- sqrt(pmax(0, z_sq_back_strict))

# Pure symmetry alpha extraction matching the input alpha mapping logic
alpha_back_strict     <- pnorm(-z_back_strict) * 2
safe_level_pct_strict <- (1 - alpha_back_strict) * 100

# Calculate non-inversion success rate with zero-division defense
non_inv_success_rate  <- ifelse(total_major_pairs > 0, (valid_non_inv_pairs / total_major_pairs) * 100, 0.0)

# --- 6. RIGID PHYSICS-BASED FILTERING ENGINE (ULTRA-FAST VECTORIZED ZERO-COPY) ---
sample_is_safe <- (!is.na(required_wt_strict) & (eff_lib_size >= required_wt_strict))

# Matrix multiplication utilizing vectorized recycling: zero memory footprint expansion
rel_status_mat <- non_zero_mask * sample_is_safe

urt_mask <- colSums(rel_status_mat) == n_s
urt_list <- colnames(P_raw)[urt_mask]

# --- 7. REPORT CONSTRUCTION & LOGGING ---
Analysis_Report <- data.frame(
  Sample_ID                        = sample_ids,
  Effective_Library_Size           = eff_lib_size,
  Surviving_Major_Components_Count = surviving_components,
  Valid_Non_Inversion_Pairs        = valid_non_inv_pairs,
  Total_Major_Pairs                = total_major_pairs,
  Non_Inversion_Success_Rate_Pct   = non_inv_success_rate,
  Required_Scale_Strict            = required_scale_strict,
  Required_wt_Strict_Worst         = required_wt_strict,
  Required_Scale_Lenient           = required_scale_lenient,
  Required_wt_Lenient_Best         = required_wt_lenient,
  Safe_Evaluation_Percent          = safe_level_pct_strict,
  row.names                        = 1
)

# Output Execution Results
print("========================================================================")
print("        TRUE POST-CUTOFF ALL-PAIRWISE PHYSICS BOUNDS REPORT             ")
print("========================================================================")
print(head(Analysis_Report, n = 100))

print("========================================================================")
print("             UNIVERSAL RELIABLE TARGETS (URT LIST VIA Z_ALPHA)          ")
print("========================================================================")
if(length(urt_list) > 0) {
  print(urt_list)
} else {
  print("No components survived the global Z_alpha threshold across all samples.")
}
print("========================================================================")
